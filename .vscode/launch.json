    "version": "0.2.0",
    "configurations": [

        {
            "name": "tsx current tsx",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "runtimeArgs": ["--env-file", ".env"],
            "runtimeExecutable": "tsx",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [ // Files to exclude from debugger (e.g. call stack)
                // Node.js internal core modules
                "<node_internals>/**",
                // Ignore all dependencies (optional)
                //"${workspaceFolder}/node_modules/**",
            ],
        },
        {
            "name": "tsx index.ts",
            "type": "node",
            "request": "launch",
            "program": "./src/index.ts",
            "runtimeArgs": ["--env-file", ".env"],
            "runtimeExecutable": "tsx",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [ // Files to exclude from debugger (e.g. call stack)
                // Node.js internal core modules
                "<node_internals>/**",
                // Ignore all dependencies (optional)
                //"${workspaceFolder}/node_modules/**",
            ],
        },
        {
            "name": "tsx test.ts",
            "type": "node",
            "request": "launch",
            "program": "./src/test.ts",
            "runtimeArgs": ["--env-file", ".env"],
            "runtimeExecutable": "tsx",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [ // Files to exclude from debugger (e.g. call stack)
                // Node.js internal core modules
                "<node_internals>/**",
                // Ignore all dependencies (optional)
                //"${workspaceFolder}/node_modules/**",
            ],
        }
    ]
}